# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Your Telegram user ID (get it from @userinfobot)
ADMIN_ID=123456789

# Public IP or domain of this server
SERVER_HOST=1.2.3.4

# Port for mtprotoproxy (default: 443)
SERVER_PORT=9443

# Path to SQLite database
DB_PATH=/var/lib/tg-proxy/data.db

# Path to telemt config.toml
CONFIG_FILE=/etc/telemt/config.toml

# Hostname for fake-TLS (makes traffic look like HTTPS to this host)
FAKE_TLS_HOST=cloudflare.com

# Command to reload telemt after config changes
RELOAD_CMD=systemctl reload telemt
